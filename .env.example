# Supabase (from Project Settings > Database)
SUPABASE_DB_URL=jdbc:postgresql://<host>:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password

# Firebase (from Project Settings > Service Accounts > Generate new private key, then base64 encode the JSON)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=base64_encoded_service_account_json

# Groq AI (from Google Cloud Console > APIs & Services > Credentials)
GROQ_API_KEY=your-groq-api-key

# Razorpay (from Razorpay Dashboard > Settings > API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# JWT (generate a secure 256-bit random string)
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-chars

# CORS (comma-separated list of allowed frontend origins)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
